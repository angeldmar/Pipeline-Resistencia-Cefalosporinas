# Configuracion de IDE (JetBrains)
.idea/

# Python
__pycache__/
*.pyc
*.egg-info/

# Snakemake
.snakemake/

# Sistema operativo
.DS_Store

# Datos y resultados generados: pueden pesar varios GB y son reproducibles
# a partir de config/samples.tsv + el pipeline, por lo que no se versionan.
# Se conserva la estructura de carpetas via .gitkeep.
data/raw/*
!data/raw/.gitkeep
data/reference/*
!data/reference/.gitkeep
data/metadata/*
!data/metadata/.gitkeep

results/qc/*
!results/qc/.gitkeep
results/trimmed/*
!results/trimmed/.gitkeep
results/assemblies/*
!results/assemblies/.gitkeep
results/annotation/*
!results/annotation/.gitkeep
results/taxonomy/*
!results/taxonomy/.gitkeep
results/amr/*
!results/amr/.gitkeep
results/typing/*
!results/typing/.gitkeep
results/tables/*
!results/tables/.gitkeep
results/statistics/*
!results/statistics/.gitkeep
results/reports/*
!results/reports/.gitkeep

logs/*
!logs/.gitkeep

# Interfaz web local (parte 28): carpetas de trabajo por carga (samples.tsv
# aislado, log, estado) generadas dinamicamente por cada analisis ad-hoc.
webapp/runs/*
!webapp/runs/.gitkeep

# Seccion de validacion estadistica: muestras reales y resultados que se
# aportaran para ese analisis, mismo criterio que data/ y results/.
validacion_estadistica/muestras/*
!validacion_estadistica/muestras/.gitkeep
validacion_estadistica/resultados/*
!validacion_estadistica/resultados/.gitkeep
