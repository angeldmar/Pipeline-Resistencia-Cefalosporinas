# Configuracion de IDE (JetBrains)
.idea/

# Python
__pycache__/
*.pyc
*.egg-info/

# Snakemake
.snakemake/

# Sistema operativo
.DS_Store

# Datos y resultados generados: pueden pesar varios GB y son reproducibles
# a partir de config/samples.tsv + el pipeline, por lo que no se versionan.
# Se conserva la estructura de carpetas via .gitkeep.
data/raw/*
!data/raw/.gitkeep
data/reference/*
!data/reference/.gitkeep
data/metadata/*
!data/metadata/.gitkeep

results/qc/*
!results/qc/.gitkeep
results/trimmed/*
!results/trimmed/.gitkeep
results/assemblies/*
!results/assemblies/.gitkeep
results/annotation/*
!results/annotation/.gitkeep
results/taxonomy/*
!results/taxonomy/.gitkeep
results/amr/*
!results/amr/.gitkeep
results/typing/*
!results/typing/.gitkeep
results/tables/*
!results/tables/.gitkeep
results/statistics/*
!results/statistics/.gitkeep
results/reports/*
!results/reports/.gitkeep

logs/*
!logs/.gitkeep

# Interfaz web local (parte 28): carpetas de trabajo por carga (samples.tsv
# aislado, log, estado) generadas dinamicamente por cada analisis ad-hoc.
webapp/runs/*
!webapp/runs/.gitkeep

# Seccion de validacion estadistica.
# Las muestras reales descargadas SI se versionan (a diferencia de data/raw/
# en la herramienta operativa): son un conjunto curado y acotado para esta
# validacion, no un lote reproducible bajo demanda. Solo se ignora el Excel
# de accesiones de entrada (dato de entrada, no parte del conjunto validado).
validacion_estadistica/muestras/*.xlsx
validacion_estadistica/muestras/*.xls

# Resultados del pipeline sobre esas muestras: si se pueden regenerar
# corriendo el pipeline sobre las muestras ya versionadas, mismo criterio
# que results/ en la herramienta operativa.
validacion_estadistica/resultados/*
!validacion_estadistica/resultados/.gitkeep
